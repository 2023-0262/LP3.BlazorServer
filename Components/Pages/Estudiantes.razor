@page "/estudiantes"
@rendermode InteractiveServer

@using LP3.BlazorServer.Shared.DTOs
@using LP3.BlazorServer.Application.Services
@using LP3.BlazorServer.Domain.Enums

@inject IEstudianteService EstudianteService

<h1>📚 Gestión de Estudiantes</h1>
<p class="text-muted">
    Aquí puedes crear, consultar, editar y eliminar estudiantes
</p>

<!-- BUSCAR -->
<div class="card mb-4">
    <div class="card-body">

        <h4>🔍 Buscar Estudiante por Matrícula</h4>

        <div class="input-group">
            <input
                type="text"
                class="form-control"
                @bind="matriculaBusqueda"
                placeholder="Ej: 2024001" />

            <button class="btn btn-primary"
                    @onclick="BuscarPorMatricula">
                Buscar
            </button>
        </div>

        @if (estudianteBuscado != null)
        {
            <div class="alert alert-info mt-3">
                <strong>✓ Encontrado:</strong>
                @estudianteBuscado.Nombre
                @estudianteBuscado.Apellido
                (ID: @estudianteBuscado.Id)
            </div>
        }

    </div>
</div>

<!-- REGISTRAR -->
<div class="card mb-4">
    <div class="card-body">

        <h4>➕ Registrar Nuevo Estudiante</h4>

        <EditForm Model="nuevoEstudiante"
                  OnValidSubmit="RegistrarEstudiante">

            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="row">

                <div class="col-md-6 mb-3">
                    <label class="form-label">Nombre:</label>

                    <InputText
                        @bind-Value="nuevoEstudiante.Nombre"
                        class="form-control"
                        placeholder="Ej: Juan" />
                </div>

                <div class="col-md-6 mb-3">
                    <label class="form-label">Apellido:</label>

                    <InputText
                        @bind-Value="nuevoEstudiante.Apellido"
                        class="form-control"
                        placeholder="Ej: Pérez" />
                </div>

            </div>

            <div class="row">

                <div class="col-md-6 mb-3">
                    <label class="form-label">Matrícula:</label>

                    <InputText
                        @bind-Value="nuevoEstudiante.Matricula"
                        class="form-control"
                        placeholder="Ej: 2024001" />
                </div>

            </div>

            <button type="submit"
                    class="btn btn-success">
                ✓ Guardar Estudiante
            </button>

        </EditForm>

        @if (!string.IsNullOrEmpty(mensajeRegistro))
        {
            <div class="alert mt-3">

                @mensajeRegistro

            </div>
        }

    </div>
</div>

<!-- TABLA -->
<div class="card">

    <div class="card-body">

        <h4>
            📊 Estudiantes Registrados
            (@estudiantes.Count)
        </h4>

        @if (estudiantes.Count == 0)
        {
            <div class="alert alert-info">
                No hay estudiantes registrados aún.
            </div>
        }
        else
        {
            <div class="table-responsive">

                <table class="table table-striped table-hover">

                    <thead class="table-dark">

                        <tr>
                            <th>ID</th>
                            <th>Nombre</th>
                            <th>Apellido</th>
                            <th>Matrícula</th>
                            <th>Acciones</th>
                        </tr>

                    </thead>

                    <tbody>

                        @foreach (var est in estudiantes)
                        {
                            <tr>

                                <td>@est.Id</td>
                                <td>@est.Nombre</td>
                                <td>@est.Apellido</td>
                                <td>@est.Matricula</td>

                                <td>

                                    <button class="btn btn-warning btn-sm"
                                            @onclick="() => CargarParaEditar(est)">
                                        ✏️ Editar
                                    </button>

                                    <button class="btn btn-danger btn-sm"
                                            @onclick="() => ConfirmarEliminar(est.Id)">
                                        🗑️ Eliminar
                                    </button>

                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>
        }

    </div>

</div>

<!-- EDITAR -->
@if (editandoEstudiante != null)
{
    <div class="card mt-4 border-warning">

        <div class="card-body">

            <h4>✏️ Editar Estudiante</h4>

            <EditForm Model="editandoEstudiante"
                      OnValidSubmit="GuardarCambios">

                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="row">

                    <div class="col-md-6 mb-3">

                        <label class="form-label">Nombre:</label>

                        <InputText
                            @bind-Value="editandoEstudiante.Nombre"
                            class="form-control" />

                    </div>

                    <div class="col-md-6 mb-3">

                        <label class="form-label">Apellido:</label>

                        <InputText
                            @bind-Value="editandoEstudiante.Apellido"
                            class="form-control" />

                    </div>

                </div>

                <div class="mb-3">

                    <label class="form-label">
                        Matrícula
                    </label>

                    <InputText
                        @bind-Value="editandoEstudiante.Matricula"
                        class="form-control"
                        disabled />

                </div>

                <button type="submit"
                        class="btn btn-primary">
                    ✓ Guardar Cambios
                </button>

                <button type="button"
                        class="btn btn-secondary"
                        @onclick="CancelarEdicion">
                    Cancelar
                </button>

            </EditForm>

        </div>

    </div>
}

<!-- ELIMINAR -->
@if (mostrarConfirmacionEliminar)
{
    <div class="card mt-4 border-danger">

        <div class="card-body">

            <div class="alert alert-danger">

                <h5>⚠️ Confirmar Eliminación</h5>

                <p>
                    ¿Está seguro de que desea eliminar este estudiante?
                </p>

                <button class="btn btn-danger"
                        @onclick="EliminarEstudiante">
                    Sí, eliminar
                </button>

                <button class="btn btn-secondary"
                        @onclick="CancelarEliminar">
                    Cancelar
                </button>

            </div>

        </div>

    </div>
}

@code {

private ICollection<EstudianteDto> estudiantes = [];

private string mensajeRegistro = string.Empty;

private string matriculaBusqueda = string.Empty;

private EstudianteDto? estudianteBuscado;

private EstudianteDto nuevoEstudiante = new();

private EstudianteDto? editandoEstudiante;

private int idEstudianteEditando = 0;

private bool mostrarConfirmacionEliminar = false;

private int idEstudianteAEliminar = 0;

protected override async Task OnInitializedAsync()
{
    await CargarEstudiantes();
}

private async Task CargarEstudiantes()
{
    estudiantes = await EstudianteService.GetAll();
}

private async Task BuscarPorMatricula()
{
    estudianteBuscado =
        await EstudianteService
        .GetByMatriculaAsync(matriculaBusqueda);
}

private async Task RegistrarEstudiante()
{
    bool resultado =
        await EstudianteService
        .CreateAsync(nuevoEstudiante);

    if (resultado)
    {
        mensajeRegistro =
            "✅ Estudiante registrado exitosamente";

        nuevoEstudiante = new();

        await CargarEstudiantes();
    }
    else
    {
        mensajeRegistro =
            "❌ Error al registrar";
    }
}

private void CargarParaEditar(EstudianteDto estudiante)
{
    editandoEstudiante = new EstudianteDto
    {
        Id = estudiante.Id,
        Nombre = estudiante.Nombre,
        Apellido = estudiante.Apellido,
        Matricula = estudiante.Matricula
    };

    idEstudianteEditando = estudiante.Id;
}

private async Task GuardarCambios()
{
    if (editandoEstudiante == null)
        return;

    bool resultado =
        await EstudianteService
        .UpdateAsync(
            idEstudianteEditando,
            editandoEstudiante
        );

    if (resultado)
    {
        mensajeRegistro =
            "✅ Estudiante actualizado";

        editandoEstudiante = null;

        await CargarEstudiantes();
    }
    else
    {
        mensajeRegistro =
            "❌ Error al actualizar";
    }
}

private void CancelarEdicion()
{
    editandoEstudiante = null;
}

private void ConfirmarEliminar(int id)
{
    idEstudianteAEliminar = id;

    mostrarConfirmacionEliminar = true;
}

private async Task EliminarEstudiante()
{
    bool resultado =
        await EstudianteService
        .DeleteAsync(idEstudianteAEliminar);

    if (resultado)
    {
        mensajeRegistro =
            "✅ Estudiante eliminado";

        mostrarConfirmacionEliminar = false;

        await CargarEstudiantes();
    }
}

private void CancelarEliminar()
{
    mostrarConfirmacionEliminar = false;
}

}